# ----- Базовое -----
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ----- JWT (RS256) -----
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=30
RSA_PRIVATE_KEY_PATH=./private_key.pem
RSA_PUBLIC_KEY_PATH=./public_key.pem

# ----- Firebase -----
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
FIREBASE_TOKEN_CLOCK_SKEW_SECONDS=30

# ----- CORS -----
# В проде сузить: '["https://yourdomain.com"]'
CORS_ORIGINS=["*"]

# ----- ngrok (запасной вариант, не используется по умолчанию) -----
USE_NGROK=false
NGROK_AUTHTOKEN=put_your_token_here
# NGROK_DOMAIN=your-reserved.ngrok-free.app   # только если есть бронь

# ----- Cloudflare Quick Tunnel (без домена, без логина) -----
USE_CLOUDFLARED=true
CLOUDFLARED_BIN_PATH=./cloudflared

# ----- Telegram: уведомление о новом адресе туннеля -----
TELEGRAM_BOT_TOKEN=put_your_bot_token_here
TELEGRAM_CHAT_ID=put_your_channel_or_chat_id_here
